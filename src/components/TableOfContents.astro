---
interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  headings?: HeadingItem[];
  topId?: string;
}

const { title, headings = [], topId = "page-top" } = Astro.props;
const items = headings.filter((heading) => heading.depth >= 1 && heading.depth <= 2);

if (!title && !items.length) {
  return null;
}
---
<aside class="page-toc" aria-label={title}>
  <p class="page-toc__label">
    <a href={`#${topId}`}>{title}</a>
  </p>
  <nav class="page-toc__nav">
    <ol>
      {items.map((item) => (
        <li class={`page-toc__item page-toc__item--depth-${item.depth}`}>
          <a href={`#${item.slug}`}>{item.text}</a>
        </li>
      ))}
    </ol>
  </nav>
</aside>
