---
interface Props {
  href: string;
  title: string;
  summary: string;
  category: string;
  publishDate: Date;
  thumbnail: string;
  thumbnailAlt: string;
}

const { href, title, category, publishDate, thumbnail, thumbnailAlt } = Astro.props;
const formattedDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---
<article class="post-tile">
  <a class="post-tile__media" href={href}>
    <img src={thumbnail} alt={thumbnailAlt} loading="lazy" decoding="async" />
  </a>
  <div class="post-tile__meta">
    <p>{category} <span aria-hidden="true">/</span> {formattedDate}</p>
  </div>
  <h2><a href={href}>{title}</a></h2>
</article>